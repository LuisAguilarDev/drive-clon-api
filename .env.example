# Variables del entorno de desarrollo Docker (docker-compose.yml).
# Copia a `.env` y ajusta. `.env` NO se commitea.

# Hot-reload por polling de archivos.
#   true  → necesario en Docker Desktop (Windows / Mac): los eventos inotify del
#           filesystem no cruzan la VM, así que los watchers usan polling.
#   false → Linux nativo: inotify funciona, polling solo malgasta CPU. Apágalo.
# Aplica a backend (WATCHFILES_FORCE_POLLING) y frontend (CHOKIDAR_USEPOLLING).
USE_POLLING=true

# Credenciales de Google OAuth para el IdP federado de Keycloak (job keycloak-init).
# Sacalas de Google Cloud Console -> APIs & Services -> Credentials -> OAuth client.
# Redirect URI a registrar en Google:
#   http://localhost:8080/realms/driveclon/broker/google/endpoint
# Dejalas vacias para omitir el IdP de Google (solo realm + client).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
